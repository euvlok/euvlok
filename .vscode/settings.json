{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit",
    "source.fixAll.biome": "explicit"
  },
  "files.associations": {
    "*.rasi": "css",
    "*.kbd": "plaintext",
    "*.tmpl": "plaintext",
    ".chezmoiignore": "gitignore",
    ".chezmoiremove": "plaintext",
    ".envrc": "shellscript"
  },
  "files.exclude": {
    "**/.devenv": true,
    "**/.direnv": true,
    "**/.fallow/cache": true,
    "**/.jj": true,
    "**/.zig-cache": true,
    "**/node_modules": true,
    "**/result": true,
    "**/result-*": true,
    "**/target": true,
    "**/zig-cache": true,
    "**/zig-out": true
  },
  "search.exclude": {
    "**/.devenv": true,
    "**/.direnv": true,
    "**/.fallow/cache": true,
    "**/.jj": true,
    "**/.zig-cache": true,
    "**/bun.lock": true,
    "**/Cargo.lock": true,
    "**/flake.lock": true,
    "**/node_modules": true,
    "**/result": true,
    "**/result-*": true,
    "**/target": true,
    "**/zig-cache": true,
    "**/zig-out": true
  },
  "biome.enabled": true,
  "biome.requireConfiguration": true,
  "biome.lsp.bin": "./node_modules/.bin/biome",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.check.workspace": true,
  "rust-analyzer.check.extraArgs": ["--all-features"],
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.procMacro.enable": true,
  "zig.path": "zig",
  "zig.zls.enabled": "on",
  "zig.zls.path": "zls",
  "zig.formattingProvider": "zls",
  "zig.buildOnSaveProvider": "zls",
  "shellcheck.enable": true,
  "shellcheck.run": "onSave",
  "shellcheck.executablePath": "shellcheck",
  "shfmt.executablePath": "shfmt",
  "shfmt.formatIgnored": false,
  "yaml.validate": true,
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml"
    ],
    "https://json.schemastore.org/github-action.json": [
      ".github/actions/*/action.yml",
      ".github/actions/*/action.yaml"
    ],
    "https://json.schemastore.org/dependabot-2.0.json": ".github/dependabot.yml"
  },
  "markdownlint.config": {
    "MD013": false,
    "MD033": false
  },
  "Lua.runtime.version": "LuaJIT",
  "Lua.workspace.checkThirdParty": false,
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.inlayHints.enabled": "on"
  },
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.formatOnSave": true,
    "editor.suggest.insertMode": "replace"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt",
    "editor.formatOnSave": true
  },
  "[nushell]": {
    "editor.formatOnSave": true
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features",
    "editor.formatOnSave": true
  },
  "[kdl]": {
    "editor.formatOnSave": true
  },
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua",
    "editor.formatOnSave": true
  }
}
