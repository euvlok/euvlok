{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env sh
set -eu

/usr/bin/osascript -l JavaScript <<'OSA'
ObjC.import("AppKit")
ObjC.import("Foundation")

const profileName = "Catppuccin Frappé Pink"

function color(hex, alpha) {
  const red = parseInt(hex.slice(1, 3), 16) / 255
  const green = parseInt(hex.slice(3, 5), 16) / 255
  const blue = parseInt(hex.slice(5, 7), 16) / 255
  const nsColor = $.NSColor.colorWithSRGBRedGreenBlueAlpha(red, green, blue, alpha)
  return $.NSKeyedArchiver.archivedDataWithRootObject(nsColor)
}

function font(name, size) {
  const nsFont = $.NSFont.fontWithNameSize(name, size) || $.NSFont.monospacedSystemFontOfSizeWeight(size, 0)
  return $.NSKeyedArchiver.archivedDataWithRootObject(nsFont)
}

function set(dict, key, value) {
  dict.setObjectForKey(value, key)
}

const defaults = $.NSUserDefaults.standardUserDefaults
const existing = defaults.persistentDomainForName("com.apple.Terminal")
const domain = existing ? $.NSMutableDictionary.dictionaryWithDictionary(existing) : $.NSMutableDictionary.dictionary
const allSettings = domain.objectForKey("Window Settings")
const windowSettings = allSettings
  ? $.NSMutableDictionary.dictionaryWithDictionary(allSettings)
  : $.NSMutableDictionary.dictionary
const profile = $.NSMutableDictionary.dictionary

set(profile, "name", profileName)
set(profile, "type", "Window Settings")
set(profile, "ProfileCurrentVersion", 2.09)
set(profile, "columnCount", 120)
set(profile, "rowCount", 30)
set(profile, "Font", font("TX02NerdFont-Regular", 15))
set(profile, "FontAntialias", true)
set(profile, "FontHeightSpacing", 1)
set(profile, "FontWidthSpacing", 1)
set(profile, "BackgroundBlur", 0)
set(profile, "BackgroundBlurInactive", 0)
set(profile, "BackgroundSettingsForInactiveWindows", false)
set(profile, "DynamicANSIForegroundColors", false)

set(profile, "BackgroundColor", color("#303446", 1))
set(profile, "TextColor", color("#c6d0f5", 1))
set(profile, "TextBoldColor", color("#f4b8e4", 1))
set(profile, "CursorColor", color("#f4b8e4", 1))
set(profile, "SelectionColor", color("#51576d", 1))

set(profile, "ANSIBlackColor", color("#51576d", 1))
set(profile, "ANSIRedColor", color("#e78284", 1))
set(profile, "ANSIGreenColor", color("#a6d189", 1))
set(profile, "ANSIYellowColor", color("#e5c890", 1))
set(profile, "ANSIBlueColor", color("#8caaee", 1))
set(profile, "ANSIMagentaColor", color("#f4b8e4", 1))
set(profile, "ANSICyanColor", color("#81c8be", 1))
set(profile, "ANSIWhiteColor", color("#a5adce", 1))
set(profile, "ANSIBrightBlackColor", color("#626880", 1))
set(profile, "ANSIBrightRedColor", color("#e78284", 1))
set(profile, "ANSIBrightGreenColor", color("#a6d189", 1))
set(profile, "ANSIBrightYellowColor", color("#e5c890", 1))
set(profile, "ANSIBrightBlueColor", color("#8caaee", 1))
set(profile, "ANSIBrightMagentaColor", color("#f4b8e4", 1))
set(profile, "ANSIBrightCyanColor", color("#81c8be", 1))
set(profile, "ANSIBrightWhiteColor", color("#b5bfe2", 1))

set(windowSettings, profileName, profile)
set(domain, "Window Settings", windowSettings)
set(domain, "Default Window Settings", profileName)
set(domain, "Startup Window Settings", profileName)
set(domain, "DefaultProfilesVersion", 2)
set(domain, "ProfileCurrentVersion", 2.09)

defaults.setPersistentDomainForName(domain, "com.apple.Terminal")
OSA
{{- end -}}
