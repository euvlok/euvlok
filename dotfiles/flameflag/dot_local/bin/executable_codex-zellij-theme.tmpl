#!/usr/bin/env zsh
set -euo pipefail

default_fg="#c6d0f5"
default_bg="#303446"

{{- if eq .chezmoi.os "darwin" }}
if ! defaults read -g AppleInterfaceStyle >/dev/null 2>&1; then
  default_fg="#4c4f69"
  default_bg="#eff1f5"
fi
{{- else }}
if command -v gsettings >/dev/null 2>&1; then
  color_scheme="$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null || true)"
  if [[ "$color_scheme" != *"dark"* ]]; then
    default_fg="#4c4f69"
    default_bg="#eff1f5"
  fi
fi
{{- end }}

cleanup() {
  if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
    zellij action set-pane-color --reset >/dev/null 2>&1 || true
  fi
}

if [[ -n "${ZELLIJ:-}" ]] && command -v zellij >/dev/null 2>&1; then
  zellij action set-pane-color --fg "$default_fg" --bg "$default_bg" >/dev/null 2>&1 || true
  trap cleanup EXIT INT TERM
fi

codex "$@"
