# Fall back to a common terminfo entry on remote hosts without Ghostty support.
if [[ "$TERM" == "xterm-ghostty" ]] && ! infocmp xterm-ghostty &>/dev/null; then
  export TERM=xterm-256color
fi

# Prefer user-local tools installed by bootstrap and language toolchains.
typeset -U path PATH
path=("$HOME/.pi/agent/bin" "$HOME/.bun/bin" "$HOME/.bun/install/global/node_modules/.bin" "$HOME/.npm/bin" "$HOME/.local/bin" "$HOME/.cargo/bin" "$HOME/.go/bin" "$HOME/.yarn/bin" $path)
if [[ -d /run/wrappers/bin ]]; then
  path=(/run/wrappers/bin $path)
fi
export PATH

# Load Oh My Zsh without its prompt or self-update behavior.
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""  # Disabled — using starship
DISABLE_AUTO_UPDATE="true"  # Managed by chezmoi external
DISABLE_UNTRACKED_FILES_DIRTY="true"  # Faster git status in prompt

# Enable the Oh My Zsh plugins used in interactive sessions.
plugins=(
  git
  gh
  fzf
  rust
  nmap
  rsync
  colored-man-pages
  sudo
  extract
  command-not-found
  copypath
  copyfile
  zsh-autosuggestions
  fzf-tab
  zsh-syntax-highlighting
)

# Add cached completion definitions before Oh My Zsh runs compinit.
fpath=("$HOME/.cache/zsh/completions" $fpath)

source $ZSH/oh-my-zsh.sh

# Source pre-generated startup hooks to keep shell startup fast.
[[ -r "$HOME/.cache/starship/init.zsh" ]] && source "$HOME/.cache/starship/init.zsh"
[[ -r "$HOME/.cache/television/init.zsh" ]] && source "$HOME/.cache/television/init.zsh"
if [[ -r "$HOME/.cache/atuin/init.zsh" ]]; then
  source "$HOME/.cache/atuin/init.zsh"
  bindkey '^R' atuin-search
fi

# Use 1Password locally, but preserve sshd's forwarded agent in SSH sessions.
{{- if eq .chezmoi.os "darwin" }}
_1p_ssh_auth_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
_1p_ssh_auth_sock="$HOME/.1password/agent.sock"
{{- end }}
if [[ -z "${SSH_CONNECTION:-}" ]]; then
  export SSH_AUTH_SOCK="$_1p_ssh_auth_sock"
fi
unset _1p_ssh_auth_sock

# Prefer Helix for command-line editing.
export EDITOR="hx"
export VISUAL="hx"

# Shortcuts for common tools and preferred replacements.
alias v="hx"
alias vi="hx"
alias vim="hx"
alias h="hx"
alias l="eza --icons"
alias ll="eza -la --icons"
alias la="eza -la --icons"
alias lt="eza --tree --icons"
alias htop="btop"
alias neofetch="pfetch"
alias top="btop"

# yt-dlp shortcuts
_yt_dlp_script() {
  env -u PROMPT_MULTILINE_INDICATOR yt-dlp-script "$@"
}
alias m4a="_yt_dlp_script m4a"
alias m4a-cut="_yt_dlp_script m4a-cut"
alias mp3="_yt_dlp_script mp3"
alias mp3-cut="_yt_dlp_script mp3-cut"
alias mp4="_yt_dlp_script mp4"
alias mp4-cut="_yt_dlp_script mp4-cut"

# Agents Aliases
alias cc="claude --allow-dangerously-skip-permissions"
alias oo="opencode"
free() {
  local runner
  runner="$(command -v system-runner)"
  if [[ -z "$runner" ]]; then
    print -u2 "free: system-runner is not installed yet; run bootstrap first"
    return 127
  fi
  sudo -n "$runner" "$@"
}
f() {
  free "$@"
}
cx() {
  zellij-theme-run codex "$@"
}

# Nix
alias update="nix flake update --flake \$(readlink -f /etc/nixos/)"
{{- if eq .chezmoi.os "darwin" }}
rebuild() {
  nh darwin switch "$(readlink -f /etc/nixos/)" "$@"
}
check() {
  free darwin-rebuild check --flake "$(readlink -f /etc/nixos/)" "$@"
}
micfix() {
  free killall coreaudiod "$@"
}
{{- else }}
rebuild() {
  free nh os switch "$(readlink -f /etc/nixos/)" "$@"
}
check() {
  nix flake check "$(readlink -f /etc/nixos/)" "$@"
}
micfix() {
  systemctl --user restart pipewire pipewire-pulse wireplumber "$@"
}
{{- end }}
alias cza="chezmoi apply --force"

# yazi with cwd sync
function yy() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# Configure fzf to search hidden files while ignoring Git internals.
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border
  --color=bg+:#414559,bg:#303446,spinner:#f4b8e4,hl:#e78284
  --color=fg:#c6d0f5,header:#e78284,info:#f4b8e4,pointer:#f4b8e4
  --color=marker:#babbf1,fg+:#c6d0f5,prompt:#f4b8e4,hl+:#e78284
  --color=selected-bg:#51576d,border:#737994,label:#c6d0f5"

# Shadow system python
export UV_PYTHON_PREFERENCE="only-managed"

function python()  { uv run python "$@"; }
function python3() { uv run python3 "$@"; }
function pip() {
  [[ -z "$VIRTUAL_ENV" && ! -d ".venv" ]] && uv venv -q
  uv pip "$@"
}
function pip3() {
  [[ -z "$VIRTUAL_ENV" && ! -d ".venv" ]] && uv venv -q
  uv pip "$@"
}

if type compdef >/dev/null 2>&1; then
  compdef _python python python3
  compdef _pip pip pip3
fi

# Load zoxide last so its directory-jump hook wins.
[[ -r "$HOME/.cache/zoxide/init.zsh" ]] && source "$HOME/.cache/zoxide/init.zsh"
alias cd="z"
