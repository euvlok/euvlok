model = "gpt-5.5"
model_reasoning_effort = "high"
suppress_unstable_features_warning = true

[features]
in_app_browser = true
browser_use = true
browser_use_external = true
computer_use = true

[tui]
notification_condition = "always"
show_tooltips = false
status_line = ["model-with-reasoning", "project-name", "context-remaining", "five-hour-limit", "weekly-limit"]
status_line_use_colors = true

[mcp_servers.ghidra]
url = "http://127.0.0.1:8090/mcp"
startup_timeout_sec = 60
tool_timeout_sec = 1800
enabled_tools = [
  "list_instances",
  "connect_instance",
  "check_tools",
  "import_file",
  "get_current_program_info",
  "list_open_programs",
  "list_project_files",
  "get_project_info",
  "open_project",
  "load_program",
  "load_program_from_project",
  "switch_program",
  "save_program",
  "analysis_status",
  "run_analysis",
  "reanalyze",
  "get_address_spaces",
  "list_functions",
  "list_functions_enhanced",
  "search_functions",
  "search_functions_enhanced",
  "get_function_by_address",
  "get_function_signature",
  "get_function_variables",
  "get_function_callers",
  "get_function_callees",
  "get_function_call_graph",
  "get_function_xrefs",
  "get_xrefs_to",
  "get_xrefs_from",
  "get_bulk_xrefs",
  "decompile_function",
  "force_decompile",
  "disassemble_function",
  "disassemble_bytes",
  "get_function_pcode",
  "analyze_dataflow",
  "analyze_data_region",
  "analyze_function_completeness",
  "analyze_for_documentation",
  "batch_decompile",
  "detect_array_bounds",
  "list_strings",
  "search_strings",
  "list_imports",
  "list_exports",
  "get_entry_points",
  "list_segments",
  "list_data_items",
  "list_data_items_by_xrefs",
  "list_globals",
  "search_byte_patterns",
  "search_instructions",
  "read_memory",
  "inspect_memory_content",
  "list_data_types",
  "search_data_types",
  "get_type_size",
  "get_struct_layout",
  "create_struct",
  "add_struct_field",
  "modify_struct_field",
  "remove_struct_field",
  "validate_data_type_exists",
  "validate_function_prototype",
  "batch_set_variable_types",
  "set_variables",
  "set_global",
  "audit_global",
  "audit_globals_in_function",
  "rename_function_by_address",
  "rename_variables",
  "rename_or_label",
  "batch_rename_function_components",
  "set_plate_comment",
  "set_disassembly_comment",
  "set_decompiler_comment",
  "list_bookmarks",
  "set_bookmark",
  "delete_bookmark",
  "get_plate_comment",
  "batch_set_comments",
  "set_function_prototype",
  "set_local_variable_type",
  "apply_data_type",
  "analyze_function_complete",
  "analyze_call_graph",
  "emulate_function",
]

[mcp_servers.lldb]
command = "lldb-mcp-launcher"
startup_timeout_sec = 30
tool_timeout_sec = 1800
enabled_tools = [
  "command",
  "debugger_list",
]
