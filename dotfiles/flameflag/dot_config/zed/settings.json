{
  "ssh_connections": [
    {
      "host": "nyx@lenovo-legion",
      "projects": [
        { "paths": ["~/nix-dotfiles"] },
        { "paths": ["~/euvlok"] },
        { "paths": ["~/nixpkgs"] }
      ],
      "upload_binary_over_ssh": false,
      "nickname": "nyx"
    }
  ],
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (pink)",
    "dark": "Catppuccin Frappé (pink)"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "auto_install_extensions": {
    "bash": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "html": true
  },
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "TX02 Nerd Font",
  "buffer_font_fallbacks": ["TX02 Nerd Font", "TX-02"],
  "terminal": {
    "font_family": "TX02 Nerd Font",
    "font_size": 15,
    "line_height": "standard",
    "shell": {
      "with_arguments": {
        "program": "/run/current-system/sw/bin/nu",
        "args": ["--login"]
      }
    },
    "env": {
      "COLORTERM": "truecolor",
      "LESS": "-R"
    }
  },
  "disable_ai": true,
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "wrap_guides": [72, 80, 120],
  "helix_mode": true,
  "languages": {
    "Nix": {
      "language_servers": ["nil"],
      "formatter": {
        "external": {
          "command": "nixfmt"
        }
      }
    },
    "YAML": {
      "language_servers": ["yaml-language-server"],
      "formatter": "language_server"
    },
    "JSON": {
      "language_servers": ["json-language-server"],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser",

            "json",

            "--stdin-filepath",

            "{buffer_path}"
          ]
        }
      }
    },
    "HTML": {
      "language_servers": ["vscode-html-language-server"],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser",

            "html",

            "--stdin-filepath",

            "{buffer_path}"
          ]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--parser",
            "css",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "Shell Script": {
      "language_servers": ["bash-language-server"],
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}", "--indent", "2"]
        }
      }
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "formatter": "language_server"
    }
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"]
        }
      }
    }
  }
}
