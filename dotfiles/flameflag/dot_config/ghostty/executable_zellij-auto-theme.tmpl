#!/bin/sh
# Stable Ghostty entrypoint. GUI-launched Ghostty doesn't reliably inherit the
# interactive shell PATH, and the managed zellij-auto-theme symlink can be absent
# briefly during bootstrap/reinstall.
set -eu

HOME_DIR={{ .chezmoi.homeDir | quote }}
PATH="$HOME_DIR/.local/bin:$HOME_DIR/.cargo/bin:$HOME_DIR/.bun/bin:$HOME_DIR/.bun/install/global/node_modules/.bin:/run/wrappers/bin:/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH

if [ -x "$HOME_DIR/.local/bin/zellij-auto-theme" ]; then
  exec "$HOME_DIR/.local/bin/zellij-auto-theme"
fi

if command -v zellij-auto-theme >/dev/null 2>&1; then
  exec zellij-auto-theme
fi

if command -v zellij >/dev/null 2>&1; then
  exec zellij options \
    --default-layout compact \
    --attach-to-session true \
    --on-force-close quit \
    --session-name "${USER:-flame}"
fi

exec "${SHELL:-/bin/zsh}" -l
