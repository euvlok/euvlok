(defcfg
  process-unmapped-keys yes
  log-layer-changes yes
)

(defsrc
  esc caps lctl lmet rmet rctl w    a    s    d         ret             \
)

(defalias
  caps-hyper (tap-hold-press 200 200 esc (multi lmet lctl lalt lsft (layer-while-held hyper)))
  win-up (macos-window top-half top-two-thirds top-third)
  win-left (macos-window left-half left-two-thirds first-third)
  win-down (macos-window bottom-half bottom-two-thirds bottom-third)
  win-right (macos-window right-half right-two-thirds last-third)
  win-max-almost (macos-window almost-maximize center)
  win-max (macos-window maximize)
)

(deflayer base
  caps @caps-hyper lmet lctl rctl rmet w       a         s         d         ret             \
)

(deflayer hyper
  _    _           _    _    _    _    @win-up @win-left @win-down @win-right @win-max-almost @win-max
)
