{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": ["bun"],
    "paths": {
      "@euvlok/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
