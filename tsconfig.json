{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": ["bun"],
    "paths": {
      "@euvlok/catppuccin-userstyles": ["./packages/catppuccin-userstyles/src/index.ts"],
      "@euvlok/github": ["./packages/lib/github/index.ts"],
      "@euvlok/core": ["./packages/lib/core.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
