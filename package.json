{
  "name": "euvlok",
  "private": true,
  "type": "module",
  "scripts": {
    "auto-rebase": "nix run .#auto-rebase --",
    "browser-extension-update": "bun --bun run packages/browser-extensions-update/src/index.ts",
    "build-catppuccin-userstyles": "bun --bun run scripts/build-catppuccin-userstyles.ts",
    "github:check-workflows": "bun --bun run scripts/github/check-workflows.ts",
    "github:lint-workflows": "bun --bun run scripts/github/lint-workflows.ts",
    "github:update-browser-extensions": "bun --bun run scripts/github/update-browser-extensions.ts",
    "github:update-custom-packages": "bun --bun run scripts/github/update-custom-packages.ts",
    "github:update-trivial-flake-inputs": "bun --bun run scripts/github/update-trivial-flake-inputs.ts",
    "check": "biome check --error-on-warnings --max-diagnostics=none package.json biome.jsonc tsconfig.json lib packages scripts && bun run github:check-workflows && bun run github:lint-workflows",
    "fallow": "fallow --format compact",
    "fallow:audit": "fallow audit --gate new-only",
    "format": "biome check --write --error-on-warnings --max-diagnostics=none package.json biome.jsonc tsconfig.json lib packages scripts",
    "format:check": "bun run check",
    "nvidia-prefetch": "zig build run-nvidia-prefetch --",
    "test": "bun test packages/browser-extensions-update/tests",
    "zig:lint": "nix run .#ziglint --"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/rest": "^22.0.1",
    "@stricli/core": "1.2.7",
    "cheerio": "^1.2.0",
    "consola": "3.4.2",
    "crx-util": "^1.0.0",
    "fflate": "^0.8.2",
    "figlet": "^1.11.0",
    "listr2": "^10.2.1",
    "pathe": "^2.0.3",
    "simple-git": "^3.36.0",
    "usercss-meta": "0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@actions/workflow-parser": "^0.3.57",
    "@biomejs/biome": "^2.4.15",
    "@tktco/node-actionlint": "^1.6.0",
    "@types/bun": "^1.3.14",
    "fallow": "2.73.0",
    "typescript": "^6.0.3"
  }
}
