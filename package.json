{
  "name": "euvlok",
  "private": true,
  "type": "module",
  "scripts": {
    "auto-rebase": "bun --bun run packages/auto-rebase/src/index.ts",
    "browser-extension-update": "bun --bun run packages/browser-extensions-update/src/index.ts",
    "build-catppuccin-userstyles": "bun --bun run scripts/build-catppuccin-userstyles.ts",
    "check": "biome check --error-on-warnings --max-diagnostics=none package.json biome.jsonc tsconfig.json packages scripts",
    "format": "biome check --write --error-on-warnings --max-diagnostics=none package.json biome.jsonc tsconfig.json packages scripts",
    "format:check": "bun run check",
    "nvidia-prefetch": "bun --bun run packages/nvidia-prefetch/src/index.ts",
    "test": "bun test packages/auto-rebase/tests"
  },
  "dependencies": {
    "@stricli/core": "1.2.6",
    "consola": "3.4.2",
    "fflate": "^0.8.2",
    "figlet": "^1.11.0",
    "listr2": "^10.2.1",
    "ofetch": "^1.5.1",
    "p-limit": "^7.3.0",
    "pathe": "^2.0.3",
    "usercss-meta": "0.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.13",
    "@types/figlet": "^1.7.0",
    "prettier": "^3.8.3"
  }
}
